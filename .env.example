# Database
# PostgreSQL connection URL (local Docker Compose default shown below)
DATABASE_URL=postgresql://doa:doa_local@localhost:5432/doa_next

# JWT — Access Token
# Secret key for signing access tokens (replace with a strong random string in production)
JWT_ACCESS_SECRET=

# JWT — Refresh Token
# Secret key for signing refresh tokens (must differ from access secret)
JWT_REFRESH_SECRET=
